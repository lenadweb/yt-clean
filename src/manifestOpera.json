{
  "name": "YouTube Clean: Boost, Customize & Hide Shorts",
  "version": "1.0.8",
  "description": "Boost and customize YouTube, hide Shorts, and clean up distracting interface elements.",
  "manifest_version": 3,
  "background": {
    "service_worker": "worker.js"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "**/*",
        "*"
      ],
      "use_dynamic_url": false
    }
  ],
  "sidebar_action": {
    "default_icon": "icons/128.png",
    "default_title": "Calculator",
    "default_panel": "sidebar.html"
  },
  "action": {
    "default_title": "Click to open calc"
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": [
    "storage"
  ]
}
