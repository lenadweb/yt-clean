{
  "name": "yt-clean",
  "version": "1.0.37",
  "description": "Browser extension that declutters YouTube — hide Shorts, ads, sidebar items, and more.",
  "license": "MIT",
  "author": "lenadweb",
  "repository": {
    "type": "git",
    "url": "https://github.com/lenadweb/yt-clean.git"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.9"
  },
  "scripts": {
    "dev": "webpack --env development --watch",
    "bump": "node bumpVersion.js",
    "build": "webpack --env platform=chrome",
    "build:chrome": "node bumpVersion.js && webpack --env platform=chrome",
    "build:opera": "node bumpVersion.js && webpack --env platform=opera",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "classnames": "^2.5.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-shadow": "^20.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/chrome": "^0.1.43",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/webpack-env": "^1.18.8",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "postcss": "^8.5.15",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.8.3",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.3.0",
    "terser-webpack-plugin": "^5.6.1",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^6.0.3",
    "vitest": "^2.1.9",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-sources": "^3.5.0",
    "zip-webpack-plugin": "^4.0.3"
  }
}
